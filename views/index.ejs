<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="Kurd Cut is the modern booking platform for barbers, hair salons, beauty salons, and nail shops. Discover trusted professionals and manage your business.">
    
    <!-- Bootstrap 5 Grid System ONLY (No Bootstrap Themes/Components to preserve custom luxury UI) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-grid.min.css" rel="stylesheet" integrity="sha384-s1SjXFEi1+mFkXl/hC2r5oGZ1oT9X6X8z1sK6z7B+7oI7p7s3v8TzZ3/B+E7oP" crossorigin="anonymous">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="theme-dark">
    <!-- Custom Cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <header class="navbar hidden-onload">
        <div class="navbar-container">
            <a href="#" class="brand-logo">KURD CUT</a>
            
            <nav class="nav-links">
                <a href="/#discover" class="nav-link" data-lang="en">Discover</a>
                <a href="/business-subscription" class="nav-link" data-lang="en">For Business</a>
                <a href="/#app" class="nav-link" data-lang="en">The App</a>
            </nav>

            <div class="nav-actions">
                <div class="lang-selector">
                    <button class="lang-btn active" data-locale="en">EN</button>
                    <button class="lang-btn" data-locale="ku">KU</button>
                    <button class="lang-btn" data-locale="ar">AR</button>
                </div>
                <a href="#download" class="btn-primary" data-lang="en">Get the App</a>
            </div>
            
            <button class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </button>
        </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section id="hero" class="hero-section">
            <div class="hero-content">
                <h1 class="hero-title">
                    <span class="reveal-text">The New Standard</span>
                </h1>
                <h1 class="hero-title secondary">
                    <span class="reveal-text serif-italic">in Grooming & Beauty.</span>
                </h1>
                <p class="hero-subtitle reveal-text delay-1">
                    Discover elite barbers, hair salons, and nail artists. Book seamlessly.
                </p>
                <div class="hero-ctas reveal-text delay-2">
                    <a href="#discover" class="btn-primary large">Book Now</a>
                    <a href="/business-subscription" class="btn-secondary large">Partner With Us</a>
                </div>
            </div>
            <div class="hero-imagery">
                <!-- Abstract dark shape or subtle vignette here (CSS driven) -->
                <div class="ambient-glow"></div>
            </div>
        </section>

        <!-- Mission / Overview -->
        <section id="mission" class="mission-section section-padding">
            <div class="container">
                <h2 class="section-title fade-up">Elevating the Experience.</h2>
                <div class="mission-grid">
                    <p class="mission-text fade-up delay-1">
                        Kurd Cut is not just an appointment app. It is a curated ecosystem where modern design meets flawless utility. We bring the world's best professionals to your fingertips.
                    </p>
                    <div class="mission-stats fade-up delay-2">
                        <div class="stat">
                            <span class="stat-number">#1</span>
                            <span class="stat-label">Platform Choice</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">0</span>
                            <span class="stat-label">Compromises</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dual Audience Section -->
        <section id="ecosystem" class="dual-ecosystem section-padding">
            <div class="container">
                <div class="split-layout">
                    <!-- Customer Side -->
                    <div class="split-pane customer-pane fade-up">
                        <span class="pane-label">For Customers</span>
                        <h3 class="pane-title">Discover the Best.</h3>
                        <ul class="feature-list">
                            <li>Explore top-rated barbers, salons, and nail shops.</li>
                            <li>Choose your perfect slot and send booking requests.</li>
                            <li>Free forever. Instant status notifications.</li>
                        </ul>
                        <a href="#download" class="btn-link">Download App &rarr;</a>
                    </div>
                    
                    <!-- Business Side -->
                    <div class="split-pane business-pane fade-up delay-1">
                        <span class="pane-label">For Businesses</span>
                        <h3 class="pane-title">Command Your Brand.</h3>
                        <ul class="feature-list">
                            <li>Receive, accept, or reject requests instantly.</li>
                            <li>Exclusive dashboard for revenue & analytics.</li>
                            <li>Premium subscription, fully controlled access.</li>
                        </ul>
                        <a href="/business-subscription" class="btn-link">Become a Partner &rarr;</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- App Showcase -->
        <section id="app" class="app-showcase section-padding">
            <div class="container text-center">
                <h2 class="section-title fade-up">Designed for Perfection.</h2>
                <p class="section-subtitle fade-up delay-1">Experience the beautifully crafted mobile application.</p>
                
                <div class="mockup-container fade-up delay-2">
                    <div class="mockup-frame">
                        <div class="mockup-screen bg-placeholder">
                            <!-- Placeholder for actual app UI image -->
                            <div class="ui-skeleton">
                                <div class="skel-header"></div>
                                <div class="skel-card"></div>
                                <div class="skel-card"></div>
                                <div class="skel-card"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <h2>KURD CUT</h2>
                <p>The premium booking standard.</p>
            </div>
            <div class="footer-links">
                <div class="link-group">
                    <h4>Platform</h4>
                    <a href="/#discover">Discover</a>
                    <a href="/business-subscription">For Business</a>
                </div>
                <div class="link-group">
                    <h4>Company</h4>
                    <a href="/terms">Terms of Service</a>
                    <a href="/privacy">Privacy Policy</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Kurd Cut. All rights reserved.</p>
        </div>
    </footer>

    <!-- jQuery (Requested for future Plugin usage) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Scripts -->
    <script src="/js/main.js"></script>
</body>
</html>
