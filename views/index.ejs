<!DOCTYPE html>
<html lang="<%= __('lang') %>" dir="<%= __('dir') %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('title_index') %></title>
    <meta name="description" content="<%= __('meta_desc') %>">
    
    <!-- Bootstrap 5 Grid System ONLY (No Bootstrap Themes/Components to preserve custom luxury UI) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-grid.min.css" rel="stylesheet" integrity="sha384-s1SjXFEi1+mFkXl/hC2r5oGZ1oT9X6X8z1sK6z7B+7oI7p7s3v8TzZ3/B+E7oP" crossorigin="anonymous">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="theme-dark">
    <!-- Custom Cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <header class="navbar hidden-onload">
        <div class="navbar-container">
            <a href="#" class="brand-logo">KURD CUT</a>
            
            <nav class="nav-links">
                <a href="/#discover" class="nav-link" data-lang="<%= __('lang') %>"><%= __('nav_discover') %></a>
                <a href="/business-subscription" class="nav-link" data-lang="<%= __('lang') %>"><%= __('nav_business') %></a>
                <a href="/#app" class="nav-link" data-lang="<%= __('lang') %>"><%= __('nav_app') %></a>
            </nav>

            <div class="nav-actions">
                <div class="lang-selector">
                    <button class="lang-btn <%= __('lang') === 'en' ? 'active' : '' %>" data-locale="en" onclick="window.location.href='?lang=en'">EN</button>
                    <button class="lang-btn <%= __('lang') === 'ckb' ? 'active' : '' %>" data-locale="ku" onclick="window.location.href='?lang=ku'">KU</button>
                    <button class="lang-btn <%= __('lang') === 'ar' ? 'active' : '' %>" data-locale="ar" onclick="window.location.href='?lang=ar'">AR</button>
                </div>
                <a href="#download" class="btn-primary" data-lang="<%= __('lang') %>"><%= __('nav_get_app') %></a>
            </div>
            
            <button class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </button>
        </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section id="hero" class="hero-section">
            <div class="hero-content">
                <h1 class="hero-title">
                    <span class="reveal-text"><%= __('hero_standard') %></span>
                </h1>
                <h1 class="hero-title secondary">
                    <span class="reveal-text serif-italic"><%= __('hero_grooming') %></span>
                </h1>
                <p class="hero-subtitle reveal-text delay-1">
                    <%= __('hero_subtitle') %>
                </p>
                <div class="hero-ctas reveal-text delay-2">
                    <a href="#discover" class="btn-primary large"><%= __('hero_book_now') %></a>
                    <a href="/business-subscription" class="btn-secondary large"><%= __('hero_partner') %></a>
                </div>
            </div>
            <div class="hero-imagery">
                <!-- Abstract dark shape or subtle vignette here (CSS driven) -->
                <div class="ambient-glow"></div>
            </div>
        </section>

        <!-- Mission / Overview -->
        <section id="mission" class="mission-section section-padding">
            <div class="container">
                <h2 class="section-title fade-up"><%= __('mission_title') %></h2>
                <div class="mission-grid">
                    <p class="mission-text fade-up delay-1">
                        <%= __('mission_text') %>
                    </p>
                    <div class="mission-stats fade-up delay-2">
                        <div class="stat">
                            <span class="stat-number">#1</span>
                            <span class="stat-label"><%= __('stat_platform') %></span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">0</span>
                            <span class="stat-label"><%= __('stat_compromise') %></span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dual Audience Section -->
        <section id="ecosystem" class="dual-ecosystem section-padding">
            <div class="container">
                <div class="split-layout">
                    <!-- Customer Side -->
                    <div class="split-pane customer-pane fade-up">
                        <span class="pane-label"><%= __('eco_customer_label') %></span>
                        <h3 class="pane-title"><%= __('eco_customer_title') %></h3>
                        <ul class="feature-list">
                            <li><%= __('eco_customer_f1') %></li>
                            <li><%= __('eco_customer_f2') %></li>
                            <li><%= __('eco_customer_f3') %></li>
                        </ul>
                        <a href="#download" class="btn-link"><%- __('eco_customer_btn') %></a>
                    </div>
                    
                    <!-- Business Side -->
                    <div class="split-pane business-pane fade-up delay-1">
                        <span class="pane-label"><%= __('eco_biz_label') %></span>
                        <h3 class="pane-title"><%= __('eco_biz_title') %></h3>
                        <ul class="feature-list">
                            <li><%= __('eco_biz_f1') %></li>
                            <li><%= __('eco_biz_f2') %></li>
                            <li><%= __('eco_biz_f3') %></li>
                        </ul>
                        <a href="/business-subscription" class="btn-link"><%- __('eco_biz_btn') %></a>
                    </div>
                </div>
            </div>
        </section>

        <!-- App Showcase -->
        <section id="app" class="app-showcase section-padding">
            <div class="container text-center">
                <h2 class="section-title fade-up"><%= __('app_title') %></h2>
                <p class="section-subtitle fade-up delay-1"><%= __('app_subtitle') %></p>
                
                <div class="mockup-container fade-up delay-2">
                    <div class="mockup-frame">
                        <div class="mockup-screen bg-placeholder">
                            <!-- Placeholder for actual app UI image -->
                            <div class="ui-skeleton">
                                <div class="skel-header"></div>
                                <div class="skel-card"></div>
                                <div class="skel-card"></div>
                                <div class="skel-card"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <h2>KURD CUT</h2>
                <p><%= __('footer_slogan') %></p>
            </div>
            <div class="footer-links">
                <div class="link-group">
                    <h4><%= __('footer_platform') %></h4>
                    <a href="/#discover"><%= __('nav_discover') %></a>
                    <a href="/business-subscription"><%= __('nav_business') %></a>
                </div>
                <div class="link-group">
                    <h4><%= __('footer_company') %></h4>
                    <a href="/terms"><%= __('footer_terms') %></a>
                    <a href="/privacy"><%= __('footer_privacy') %></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p><%- __('footer_copyright') %></p>
        </div>
    </footer>

    <!-- jQuery (Requested for future Plugin usage) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Scripts -->
    <script src="/js/main.js"></script>
</body>
</html>
