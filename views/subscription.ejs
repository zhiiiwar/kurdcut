<!DOCTYPE html>
<html lang="<%= __('lang') %>" dir="<%= __('dir') %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('title_subscription') %></title>
    
    <!-- Bootstrap 5 Grid System ONLY -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-grid.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="/css/styles.css">
    
    <style>
        .subscription-header {
            padding: 20vh 0 10vh;
            border-bottom: 1px solid var(--color-border);
            margin-bottom: var(--spacing-xl);
            text-align: center;
        }
        .intro-text {
            font-size: clamp(1.25rem, 2vw, 1.75rem);
            color: var(--color-text-secondary);
            max-width: 800px;
            margin: 0 auto var(--spacing-xl);
            font-weight: 300;
            line-height: 1.6;
        }
        
        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: var(--spacing-md);
            margin-bottom: var(--spacing-xxl);
        }
        
        .benefit-card {
            background-color: var(--color-surface);
            padding: var(--spacing-lg);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            transition: transform var(--transition-base), background-color var(--transition-base);
        }
        
        .benefit-card:hover {
            background-color: var(--color-bg-alt);
            transform: translateY(-5px);
        }
        
        .benefit-title {
            font-family: var(--font-serif);
            font-size: 1.5rem;
            margin-bottom: var(--spacing-sm);
        }

        .benefit-desc {
            color: var(--color-text-secondary);
            font-size: 1rem;
            line-height: 1.6;
        }

        .contact-box {
            background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg-alt) 100%);
            border: 1px solid var(--color-border);
            border-radius: 20px;
            padding: var(--spacing-xl);
            text-align: center;
            max-width: 900px;
            margin: 0 auto;
        }

        .contact-title {
            font-size: 2.5rem;
            margin-bottom: var(--spacing-md);
        }

        .contact-desc {
            color: var(--color-text-secondary);
            font-size: 1.125rem;
            margin-bottom: var(--spacing-lg);
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
    </style>
</head>
<body class="theme-dark">
    <!-- Custom Cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <header class="navbar scrolled">
        <div class="navbar-container">
            <a href="/" class="brand-logo">KURD CUT</a>
            <div class="nav-actions">
                <a href="/" class="btn-secondary"><%= __('nav_return') %></a>
            </div>
            <button class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </button>
        </div>
    </header>

    <main class="container">
        <div class="subscription-header fade-up">
            <h1 class="hero-title" style="font-size: clamp(2rem, 5vw, 4rem);"><%= __('sub_hero_1') %></h1>
            <h2 class="hero-title secondary"><span class="serif-italic" style="font-size: clamp(1.5rem, 4vw, 3rem);"><%= __('sub_hero_2') %></span></h2>
        </div>

        <p class="intro-text text-center fade-up delay-1">
            <%= __('sub_intro') %>
        </p>

        <div class="benefits-grid fade-up delay-2">
            <div class="benefit-card">
                <h3 class="benefit-title"><%= __('sub_b1_title') %></h3>
                <p class="benefit-desc"><%= __('sub_b1_desc') %></p>
            </div>
            <div class="benefit-card">
                <h3 class="benefit-title"><%= __('sub_b2_title') %></h3>
                <p class="benefit-desc"><%= __('sub_b2_desc') %></p>
            </div>
            <div class="benefit-card">
                <h3 class="benefit-title"><%= __('sub_b3_title') %></h3>
                <p class="benefit-desc"><%= __('sub_b3_desc') %></p>
            </div>
        </div>

        <div class="contact-box fade-up delay-1" style="margin-bottom: var(--spacing-xxl);">
            <h2 class="contact-title"><%= __('sub_contact_title') %></h2>
            <p class="contact-desc">
                <%= __('sub_contact_desc') %>
            </p>
            <div style="display: flex; gap: var(--spacing-sm); justify-content: center; flex-wrap: wrap;">
                <a href="mailto:partnerships@kurdcut.com" class="btn-primary large"><%= __('sub_btn_email') %></a>
                <a href="tel:+1234567890" class="btn-secondary large"><%= __('sub_btn_call') %></a>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <h2>KURD CUT</h2>
                <p><%= __('footer_slogan') %></p>
            </div>
            <div class="footer-links">
                <div class="link-group">
                    <h4><%= __('footer_platform') %></h4>
                    <a href="/#discover"><%= __('nav_discover') %></a>
                    <a href="/business-subscription"><%= __('nav_business') %></a>
                </div>
                <div class="link-group">
                    <h4><%= __('footer_company') %></h4>
                    <a href="/terms"><%= __('footer_terms') %></a>
                    <a href="/privacy"><%= __('footer_privacy') %></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p><%- __('footer_copyright') %></p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
